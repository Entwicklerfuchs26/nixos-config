{
  "compositor": "hyprland",
  "monitor": "",
  "paths": {
    "wallpaper": "/home/fuchs/Pictures/Wallpapers",
    "videoWallpaper": "~/videowalls",
    "cache": "",
    "templates": "",
    "scripts": "",
    "steam": "",
    "steamWorkshop": "",
    "steamWeAssets": ""
  },
  "features": {
    "matugen": true,
    "ollama": false,
    "steam": false,
    "wallhaven": true
  },
  "colorSource": "magick",
  "matugen": {
    "schemeType": "scheme-fidelity",
    "mode": "dark"
  },
  "integrations": [
    {
      "name": "skwd-wall",
      "template": "quickshell-colors.json",
      "output": "colors.json"
    },
    {
      "name": "kitty",
      "template": "kitty.conf",
      "output": "~/.config/kitty/skwd-theme.conf",
      "reload": "pkill -USR1 kitty"
    },
    {
      "name": "waybar",
      "template": "waybar.css",
      "output": "~/.config/waybar/style.css",
      "reload": "pkill -USR2 waybar"
    },
    {
      "name": "hyprland-borders",
      "reload": "/home/fuchs/.config/skwd-wall/scripts/apply-borders-wrapper.sh"
    },
    {
      "name": "cava",
      "template": "cava.conf",
      "output": "~/.config/cava/config",
      "reload": "pkill -USR1 cava"
    },
    {
      "name": "wlogout",
      "template": "wlogout.css",
      "output": "~/.config/wlogout/style.css"
    },
    {
      "name": "nwg-dock",
      "template": "nwg-dock.css",
      "output": "~/.config/nwg-dock-hyprland/style.css",
      "reload": "~/.config/skwd-wall/scripts/reload-dock.sh"
    },
    {
      "name": "colors-sh",
      "template": "colors.sh",
      "output": "/home/fuchs/.config/matugen/colors.sh"
    },
    {
      "name": "kdeglobals",
      "template": "kdeglobals.conf",
      "output": "/home/fuchs/.config/kdeglobals"
    },
    {
      "name": "vesktop",
      "template": "vesktop.css",
      "output": "~/.config/vesktop/themes/kitty-match.css"
    },
    {
      "name": "openrgb",
      "reload": "/home/fuchs/.config/skwd-wall/scripts/openrgb-wrapper.sh"
    }
  ],
  "components": {
    "wallpaperSelector": {
      "enabled": true,
      "displayMode": "hex",
      "hexRadius": 100,
      "hexRows": 4
    }
  },
  "wallpaperMute": true,
  "performance": {
    "imageOptimizeResolution": "1080p",
    "autoDeleteImageTrash": false
  },
  "general": {
    "wallpaperPerMonitor": false,
    "randomIncludeStatic": true
  },
  "paper": {
    "engine": "skwd-paper",
    "awww": {
      "transitionType": "none"
    }
  },
  "externalMatugenConfig": "/home/fuchs/.config/matugen/config.toml",
  "externalMatugenCommand": "/run/current-system/sw/bin/matugen -c %config% image %path% --source-color-index 0"
}
